{
  "name": "workeddy/browsemx",
  "description": "WorkEddy Runtime modular monolith for tenant-aware commerce operations.",
  "type": "project",
  "license": "proprietary",
  "require": {
    "php": "^8.1",
    "doctrine/dbal": "^3.8",
    "doctrine/migrations": "^3.7",
    "dompdf/dompdf": "^3.1",
    "league/flysystem": "^3",
    "league/flysystem-local": "^3",
    "monolog/monolog": "^3.5",
    "nikic/fast-route": "^1.3",
    "php-di/php-di": "^7.0",
    "psr/cache": "^3.0",
    "psr/container": "^2.0",
    "psr/log": "^3.0",
    "ramsey/uuid": "^4.7",
    "symfony/cache": "^6.4",
    "symfony/console": "^6.4",
    "symfony/http-client": "^7.4",
    "symfony/lock": "^6.4",
    "symfony/mailer": "^7.4",
    "vlucas/phpdotenv": "^5.6"
  },
  "require-dev": {
    "phpstan/phpstan": "^1.10",
    "phpunit/phpunit": "^10.5"
  },
  "autoload": {
    "psr-4": {
      "WorkEddy\\Platform\\": "platform/",
      "WorkEddy\\Modules\\": "modules/",
      "WorkEddy\\Shared\\": "shared/",
      "WorkEddy\\Migrations\\": "migrations/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "WorkEddy\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "analyse": "phpstan analyse --memory-limit=512M",
    "test": "php tests/run.php",
    "validate:iam": "phpunit -c phpunit.xml tests/IAM/RouteAuthorizationCoverageTest.php"
  },
  "config": {
    "sort-packages": true
  }
}
