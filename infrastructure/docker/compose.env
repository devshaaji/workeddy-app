# Container-internal runtime overrides for docker compose services.
# Keep secrets in the project .env; this file only corrects network-local hosts
# and safe service defaults inside the Docker network.

APP_ENV=production
DB_HOST=mysql
DB_PORT=3306
DB_USER=workeddy
DB_NAME=workeddy
DB_PASSWORD=workeddy
MYSQL_DATABASE=workeddy
MYSQL_USER=workeddy
MYSQL_PASSWORD=workeddy
WORKER_API_BASE_URL=http://nginx
WorkEddy_VIDEO_WORKER_STORAGE_ROOT=/storage
