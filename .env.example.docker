#--------------------------------------------------------------------
# APPLICATION
#--------------------------------------------------------------------
APP_NAME=WorkEddy
APP_TAGLINE=""
APP_ENV=development
APP_RUNTIME=WorkEddy
APP_DEBUG=false
APP_URL=http://localhost
APP_TIMEZONE=Africa/Lagos
APP_PROFILE=shared
APP_KEY=local-WorkEddy-qa-key-000000000000000000

#--------------------------------------------------------------------
# DATABASE (Doctrine DBAL inside Docker container network)
#--------------------------------------------------------------------
DB_DRIVER=pdo_mysql
DB_HOST=mysql
DB_PORT=3306
DB_NAME=workeddy
DB_USER=workeddy
DB_PASSWORD=workeddy
DB_ROOT_PASS=rootsecret
DB_CHARSET=utf8mb4

#--------------------------------------------------------------------
# CACHE & QUEUE
#--------------------------------------------------------------------
WorkEddy_CACHE_DRIVER=filesystem
WorkEddy_CACHE_NAMESPACE=WorkEddy
CACHE_DEFAULT_TTL=300

WorkEddy_QUEUE_DRIVER=database
WorkEddy_QUEUE_DEFAULT=default
WorkEddy_QUEUE_MAX_ATTEMPTS=3
WorkEddy_QUEUE_RETRY_DELAY_SECONDS=60
WorkEddy_QUEUE_LOCK_SECONDS=120
WorkEddy_QUEUE_WORKER_LIMIT=25
WorkEddy_QUEUE_MAINTENANCE_LIMIT=100

# Docker startup workers
DOCKER_START_QUEUE_WORKERS=1
DOCKER_START_CRON_DAEMON=1
QUEUE_WORKER_INTERVAL_SECONDS=5
HIGH_PRIORITY_QUEUE_WORKER_INTERVAL_SECONDS=5
HIGH_PRIORITY_QUEUE_WORKER_LIMIT=25

# Assessment video worker
WORKER_API_BASE_URL=http://nginx
WORKER_API_TOKEN=replace-with-shared-worker-token
WorkEddy_VIDEO_WORKER_STORAGE_ROOT=/storage
VIDEO_CLEANUP_INTERVAL_SECONDS=86400

#--------------------------------------------------------------------
# LOCK & LOG
#--------------------------------------------------------------------
WorkEddy_LOCK_DRIVER=flock
WorkEddy_LOG_LEVEL=debug
WorkEddy_SECURITY_LOG_LEVEL=debug

#--------------------------------------------------------------------
# MAIL
#--------------------------------------------------------------------
MAIL_ENABLED=true
MAIL_HOST=smtp.hostinger.com
MAIL_PORT=465
MAIL_ENCRYPTION=ssl
MAIL_USERNAME=admin@workeddy.com
MAIL_PASSWORD=your-admin-mailbox-password
MAIL_FROM_ADDRESS=no-reply@workeddy.com
MAIL_FROM_NAME=WorkEddy
MAIL_REPLY_TO_ADDRESS=support@workeddy.com
MAIL_REPLY_TO_NAME="WorkEddy Support"

#--------------------------------------------------------------------
# PLATFORM SERVICES
#--------------------------------------------------------------------
WorkEddy_ROUTE_CACHE=true
WorkEddy_CONTAINER_COMPILE=false
